<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE config SYSTEM "https://www.matsim.org/files/dtd/config_v2.dtd">
<config>

    <!-- ============================================================
         GLOBAL
         14700HX: 20 cores (8P + 12E), 28 threads
         Use 24 threads — leave 4 for OS + JVM GC
         ============================================================ -->
    <module name="global">
        <param name="coordinateSystem" value="EPSG:32647"/>
        <param name="numberOfThreads" value="24"/>
    </module>

    <!-- ============================================================
         CONTROLLER
         ============================================================ -->
    <module name="controller">
        <param name="outputDirectory" value="output"/>
        <param name="lastIteration" value="50"/>
        <param name="writeEventsInterval" value="50"/>
        <param name="writePlansInterval" value="50"/>
        <param name="mobsim" value="hermes"/>
    </module>

    <!-- ============================================================
         NETWORK
         ============================================================ -->
    <module name="network">
        <param name="inputNetworkFile" value="processed/network_condition.xml.gz"/>
    </module>

    <!-- ============================================================
         PLANS
         ============================================================ -->
    <module name="plans">
        <param name="inputPlansFile" value="../preprocess/output/plan_300k_cut.xml"/>
    </module>

    <!-- ============================================================
         HERMES
         - flowCapacityFactor เพิ่มจาก 0.1 → 0.15 (รถติดเกินจริง)
         - storageCapacityFactor เพิ่มจาก 0.1 → 0.15
         - stuckTime คงไว้ที่ 1200
         ============================================================ -->
    <module name="hermes">
        <param name="mainMode" value="car"/>
        <param name="flowCapacityFactor" value="0.10"/>
        <param name="storageCapacityFactor" value="0.10"/>
        <param name="stuckTime" value="600"/>
    </module>

    <!-- ============================================================
         ROUTING
         ============================================================ -->
    <module name="routing">
        <param name="clearDefaultTeleportedModeParams" value="true"/>

        <parameterset type="teleportedModeParameters">
            <param name="mode" value="pt"/>
            <param name="teleportedModeSpeed" value="8.0"/>
        </parameterset>

        <parameterset type="teleportedModeParameters">
            <param name="mode" value="walk"/>
            <param name="teleportedModeSpeed" value="1.34"/>
        </parameterset>
    </module>

    <!-- ============================================================
         SCORING
         - marginalUtilityOfMoney = 0.062 → VTTS ≈ 97 บาท/ชั่วโมง
         - modeParams car: distance cost + travel time cost
         ============================================================ -->
    <module name="scoring">
        <param name="marginalUtilityOfMoney" value="0.062"/>
        <param name="brainExpBeta" value="2.0"/>

        <parameterset type="modeParams">
            <param name="mode" value="car"/>
            <param name="monetaryDistanceRate" value="-0.0002"/>
            <param name="marginalUtilityOfTraveling_util_hr" value="-6.0"/>
        </parameterset>

        <!-- HOME: 12 hours -->
        <parameterset type="activityParams">
            <param name="activityType" value="home"/>
            <param name="typicalDuration" value="43200"/>
        </parameterset>

        <!-- WORK: 8 hours -->
        <parameterset type="activityParams">
            <param name="activityType" value="work"/>
            <param name="typicalDuration" value="28800"/>
            <param name="openingTime" value="07:00:00"/>
            <param name="closingTime" value="20:00:00"/>
            <param name="latestStartTime" value="10:00:00"/>
        </parameterset>

        <!-- EDUCATION: 6 hours -->
        <parameterset type="activityParams">
            <param name="activityType" value="education"/>
            <param name="typicalDuration" value="21600"/>
            <param name="openingTime" value="06:30:00"/>
            <param name="closingTime" value="18:00:00"/>
            <param name="latestStartTime" value="09:00:00"/>
        </parameterset>

        <!-- SHOPPING: 2 hours, malls open 10:00–21:00 -->
        <parameterset type="activityParams">
            <param name="activityType" value="shopping"/>
            <param name="typicalDuration" value="7200"/>
            <param name="openingTime" value="10:00:00"/>
            <param name="closingTime" value="21:00:00"/>
            <param name="latestStartTime" value="19:00:00"/>
        </parameterset>

        <!-- DINING: 1.5 hours, restaurants 08:00–22:00 -->
        <parameterset type="activityParams">
            <param name="activityType" value="dining"/>
            <param name="typicalDuration" value="5400"/>
            <param name="openingTime" value="08:00:00"/>
            <param name="closingTime" value="22:00:00"/>
            <param name="latestStartTime" value="21:00:00"/>
        </parameterset>

        <!-- LEISURE: 3 hours, venues 09:00–22:00 -->
        <parameterset type="activityParams">
            <param name="activityType" value="leisure"/>
            <param name="typicalDuration" value="10800"/>
            <param name="openingTime" value="09:00:00"/>
            <param name="closingTime" value="22:00:00"/>
            <param name="latestStartTime" value="20:00:00"/>
        </parameterset>

        <!-- RELIGION: 2 hours -->
        <parameterset type="activityParams">
            <param name="activityType" value="religion"/>
            <param name="typicalDuration" value="7200"/>
        </parameterset>

        <!-- PUBLIC SERVICE: 2 hours -->
        <parameterset type="activityParams">
            <param name="activityType" value="public_service"/>
            <param name="typicalDuration" value="7200"/>
        </parameterset>

        <!-- OTHER: 1 hour -->
        <parameterset type="activityParams">
            <param name="activityType" value="other"/>
            <param name="typicalDuration" value="3600"/>
        </parameterset>

    </module>

    <!-- ============================================================
         REPLANNING
         - maxAgentPlanMemorySize = 3 (ประหยัด RAM)
         - ReRoute weight เพิ่มจาก 0.10 → 0.15
         - disableAfterIteration เพิ่มจาก 20 → 40
         ============================================================ -->
    <module name="replanning">
        <param name="maxAgentPlanMemorySize" value="3"/>

        <parameterset type="strategysettings">
            <param name="strategyName" value="ChangeExpBeta"/>
            <param name="weight" value="0.85"/>
        </parameterset>

        <parameterset type="strategysettings">
            <param name="strategyName" value="ReRoute"/>
            <param name="weight" value="0.10"/>
            <param name="disableAfterIteration" value="120"/>
        </parameterset>
    </module>

</config>