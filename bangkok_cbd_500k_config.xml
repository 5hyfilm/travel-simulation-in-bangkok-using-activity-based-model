<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE config SYSTEM "http://www.matsim.org/files/dtd/config_v2.dtd">
<config>
    <!-- ======================================================================
         GLOBAL SETTINGS
         ====================================================================== -->
    <module name="global">
        <param name="coordinateSystem" value="EPSG:32647"/>
        <param name="numberOfThreads" value="24"/>
        <param name="randomSeed" value="42"/>
    </module>

    <!-- ======================================================================
         NETWORK & PLANS
         ====================================================================== -->
    <module name="network">
        <param name="inputNetworkFile" value="data/processed/network.cleaned.xml.gz"/>
    </module>

    <module name="plans">
        <param name="inputPlansFile" value="preprocess/output/plan_all.xml"/>
    </module>

    <!-- ======================================================================
         CONTROLLER
         ====================================================================== -->
    <module name="controller">
        <param name="outputDirectory" value="output/hermes_500k_cbd"/>
        <param name="firstIteration" value="0"/>
        <param name="lastIteration" value="30"/>
        <param name="mobsim" value="hermes"/>
        <param name="writeEventsInterval" value="30"/>
        <param name="writePlansInterval" value="30"/>
        <param name="overwriteFiles" value="deleteDirectoryIfExists"/>
    </module>

    <!-- ======================================================================
         HERMES ENGINE SETTINGS
         ====================================================================== -->
    <module name="hermes">
        <param name="mainMode" value="car"/>
        <param name="flowCapacityFactor" value="2.0"/>
        <param name="storageCapacityFactor" value="2.0"/>
        <param name="stuckTime" value="600"/>
        <param name="endTime" value="30:00:00"/>
    </module>

    <!-- ======================================================================
         SCORING & ACTIVITIES
         ====================================================================== -->
    <module name="scoring">
        <param name="brainExpBeta" value="2.0"/>
        
        <parameterset type="scoringParameters">
            <param name="marginalUtilityOfMoney" value="1.0"/>
            <param name="performing" value="6.0"/>
            <param name="utilityOfLineSwitch" value="-1.0"/>
            
            <parameterset type="activityParams">
                <param name="activityType" value="home"/>
                <param name="typicalDuration" value="12:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="work"/>
                <param name="typicalDuration" value="08:00:00"/>
                <param name="openingTime" value="08:00:00"/>
                <param name="closingTime" value="18:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="education"/>
                <param name="typicalDuration" value="06:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="shopping"/>
                <param name="typicalDuration" value="01:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="dining"/>
                <param name="typicalDuration" value="01:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="leisure"/>
                <param name="typicalDuration" value="02:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="religion"/>
                <param name="typicalDuration" value="01:00:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="public_service"/>
                <param name="typicalDuration" value="00:30:00"/>
            </parameterset>
            <parameterset type="activityParams">
                <param name="activityType" value="other"/>
                <param name="typicalDuration" value="01:00:00"/>
            </parameterset>

            <parameterset type="modeParams">
                <param name="mode" value="car"/>
                <param name="marginalUtilityOfTraveling_util_hr" value="-6.0"/>
            </parameterset>
            <parameterset type="modeParams">
                <param name="mode" value="walk"/>
                <param name="marginalUtilityOfTraveling_util_hr" value="-12.0"/>
            </parameterset>
            <parameterset type="modeParams">
                <param name="mode" value="pt"/>
                <param name="marginalUtilityOfTraveling_util_hr" value="-6.0"/>
            </parameterset>
        </parameterset>
    </module>

    <module name="replanning">
        <param name="maxAgentPlanMemorySize" value="1"/>
        <param name="fractionOfIterationsToDisableInnovation" value="0.8"/>
        <parameterset type="strategysettings">
            <param name="strategyName" value="BestScore"/>
            <param name="weight" value="0.9"/>
        </parameterset>
        <parameterset type="strategysettings">
            <param name="strategyName" value="ReRoute"/>
            <param name="weight" value="0.1"/>
        </parameterset>
    </module>

</config>
